# WA Mining Operations Dashboard – Git Ignore Rules
# ------------------------------------------------

# Raw CSV data (too large, downloadable from source)
# The Major_Resource_Projects.csv is available publicly from the DMIRS
# Data and Software Centre (see DATABASES/README_database.md). This keeps
# the repo lightweight and fast to clone.
# NOTE: previous pattern "DATABASES/*.csv" did not match this nested path
# and silently failed to exclude the file — fixed below.
DATABASES/raw/*.csv

# OS generated files
.DS_Store

# Backend (FastAPI)
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/.env

# Frontend (React + Vite)
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/*.tsbuildinfo

# Root (Netlify Functions + Drizzle + Netlify Database)
node_modules/
deno.lock

# Netlify CLI local runtime state (created by `netlify dev`)
.netlify/state.json
.netlify/functions-serve/
.netlify/functions-internal/
.netlify/blobs-serve/
.netlify/db/
.netlify/v1/

