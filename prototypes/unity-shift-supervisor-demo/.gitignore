# This .gitignore is scoped to prototypes/unity-shift-supervisor-demo/ only.
# It does not affect the root repo's .gitignore (backend/, frontend/, etc.).
# Based on the standard community Unity template (github/gitignore: Unity.gitignore).

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Autogenerated VS/Rider/MD solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files (for non-Assets folders)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packages/ lock file is fine to keep; Packages/manifest.json will be
# generated by Unity on first open of this project and should be committed
# once it exists (not ignored).

# OS
.DS_Store
Thumbs.db
